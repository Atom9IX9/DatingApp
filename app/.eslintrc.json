{
  "extends": [
    "next/core-web-vitals",
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "plugins": ["boundaries", "import", "prettier", "@typescript-eslint"],
  "env": { "browser": true, "node": true, "jest": true },
  "parser": "@typescript-eslint/parser",

  "settings": {
    "import/resolver": {
      "typescript": {}
    },

    "boundaries/elements": [
      { "type": "shared", "pattern": "src/shared/**/*" },
      { "type": "entities", "pattern": "src/entities/**/*" },
      { "type": "features", "pattern": "src/features/**/*" },
      { "type": "widgets", "pattern": "src/widgets/**/*" },
      { "type": "processes", "pattern": "src/processes/**/*" },
      { "type": "app", "pattern": "src/app/**/*" },
      {
        "type": "global-store",
        "pattern": ["src/root/model", "src/root/model/**/*"]
      },
      {
        "type": "root",
        "pattern": "src/root/**/*",
        "ignore": ["src/root/model", "src/root/model/**/*"]
      }
    ]
  },

  "rules": {
    "no-console": "warn",
    "prettier/prettier": "error",
    "boundaries/element-types": [
      "error",
      {
        "default": "disallow",
        "rules": [
          { "from": "shared", "allow": ["shared", "global-store"] },

          {
            "from": "entities",
            "allow": ["shared", "entities", "global-store"]
          },

          {
            "from": "features",
            "allow": ["shared", "entities", "features", "global-store"]
          },

          {
            "from": "widgets",
            "allow": [
              "shared",
              "entities",
              "features",
              "widgets",
              "global-store"
            ]
          },

          {
            "from": "processes",
            "allow": [
              "shared",
              "entities",
              "features",
              "widgets",
              "processes",
              "global-store"
            ]
          },

          {
            "from": "app",
            "allow": [
              "shared",
              "entities",
              "features",
              "widgets",
              "processes",
              "app",
              "global-store"
            ]
          },

          { "from": "root", "allow": ["*", "global-store"] },
          { "from": "global-store", "allow": ["*"] }
        ]
      }
    ],

    "import/no-restricted-paths": [
      "warn",
      {
        "zones": [
          {
            "target": "./src/features/*",
            "from": "./src/features/*/*",
            "except": ["./src/features/*/index.*"]
          },
          {
            "target": "./src/entities/*",
            "from": "./src/entities/*/*",
            "except": ["./src/entities/*/index.*"]
          },
          {
            "target": "./src/widgets/*",
            "from": "./src/widgets/*/*",
            "except": ["./src/widgets/*/index.*"]
          }
        ]
      }
    ],

    "import/no-cycle": "error",
    "import/no-internal-modules": "off",
    "no-undef": "off",
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "error",
    "import/order": [
      "error",
      {
        "groups": [
          "builtin",
          "external",
          "internal",
          "parent",
          "sibling",
          "index"
        ],
        "newlines-between": "always"
      }
    ]
  }
}
